<div style="margin-top: 2px">
  <div>
    <span>{{{message}}}</span>
  </div>

  {{#unless lock}}
  <div
    style="
      margin-top: 6px;
      display: grid;
      grid-template-columns: 50px 1fr 1fr 1fr 50px;
      align-items: center;
    "
  >
    <div
      class="adjustDie"
      data-dice="d10"
      data-adjust="demerit"
      data-type="demerit"
      title="{{localize " TA.Chat.D10DemeritAdjust"}}"
      style="justify-self: right"
    >
      <div
        style="
          display: grid;
          grid-template-columns: 1fr 1fr;
          gap: 0 5px;
          justify-items: center;
        "
      >
        <div style="justify-self: right">
          <i data-adjust="up" class="fa-solid fa-circle-plus"></i>
        </div>
        <div style="justify-self: left; font-size: 11px">{{demerit.up}}</div>
      </div>

      <div style="margin: 0 0 4px -5px">
        <img
          src="systems/triangleagency/assets/icons/demerit.svg"
          style="height: 18px; margin: 0"
        />
      </div>

      <div
        style="
          display: grid;
          grid-template-columns: 1fr 1fr;
          gap: 0 5px;
          justify-items: center;
        "
      >
        <div style="justify-self: right">
          <i data-adjust="down" class="fa-solid fa-circle-minus"></i>
        </div>
        <div style="justify-self: left; font-size: 11px">{{demerit.down}}</div>
      </div>
    </div>

    <div style="padding-right: 6px">
      <hr />
    </div>

    <div title="{{localize "TA.Dialog.UnambiguousDie"}}">
      <img
        src="systems/triangleagency/assets/icons/d10-outcome-{{primary.result.pip}}.png"
        style="width: 50px"
      />
    </div>

    <div style="padding-left: 6px">
      <hr />
    </div>

    <div
      class="adjustDie"
      data-dice="d10"
      data-adjust="qa"
      data-type="qa"
      title="{{localize "TA.Chat.D10QAAdjust"}}"
      style="padding-left: 6px; justify-self: left"
    >
      <div
        style="
          display: grid;
          grid-template-columns: 1fr 1fr;
          gap: 0 5px;
          justify-items: center;
        "
      >
        <div style="justify-self: right">
          <i data-adjust="up" class="fa-solid fa-circle-plus"></i>
        </div>
        <div style="justify-self: left; font-size: 11px">{{qa.up}}</div>
      </div>
      <div style="margin: 0 0 4px -5px">
        <img
          src="systems/triangleagency/assets/icons/qa.png"
          style="height: 18px"
        />
      </div>
      <div
        style="
          display: grid;
          grid-template-columns: 1fr 1fr;
          gap: 0 5px;
          justify-items: center;
        "
      >
        <div style="justify-self: right">
          <i data-adjust="down" class="fa-solid fa-circle-minus"></i>
        </div>
        <div style="justify-self: left; font-size: 11px">{{qa.down}}</div>
      </div>
    </div>
  </div>

  {{#if supplement.active}}
  <div
    style="
      margin-top: 6px;
      display: grid;
      grid-template-columns: 50px 1fr 1fr 1fr 50px;
      align-items: center;
    "
  >
    <div style="padding-right: 8px; justify-self: right" title="{{localize "TA.Chat.D6DemeritAdjust"}}">
      <img
        class="adjustDie"
        data-adjust="setFace"
        data-type="demerit"
        data-dice="d6"
        src="systems/triangleagency/assets/icons/demerit.svg"
        style="height: 18px; cursor: pointer"
      />
    </div>

    <div style="padding-right: 6px">
      <hr />
    </div>

    <div title="{{localize "TA.Dialog.UncommendableDie"}}" style="justify-self: center">
      <img
        src="systems/triangleagency/assets/icons/d6-outcome-{{supplement.result.pip}}.png"
        style="width: 35px"
      />
    </div>

    <div style="padding-left: 6px">
      <hr />
    </div>

    <div style="padding-left: 8px; justify-self: left" title="{{localize "TA.Chat.D6QAAdjust"}}">
      <img
        class="adjustDie"
        data-adjust="setFace"
        data-type="qa"
        data-dice="d6"
        src="systems/triangleagency/assets/icons/qa.png"
        style="height: 18px; cursor: pointer"
      />
    </div>
  </div>
  {{/if}}

  <div
    style="
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 0 5px;
      margin-top: 10px;
    "
  >
    <div
      style="
        justify-self: left;
        align-self: end;
        font-size: 14pt;
        padding: 0 0 6px 10px;
      "
    >
      <img
        class="icon"
        src="systems/triangleagency/assets/icons/demerit.svg"
        style="
          height: 18px;
          margin-top: -3px;
          margin-left: auto;
          margin-right: auto;
        "
        title="{{localize " TA.Chat.ClickToReset"}}"
      />
      <span style="display: inline-block; margin-left: 2px"> {{demerit.remaining}} / {{demerit.max}} </span>
    </div>

    <div
      style="
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0 10px;
        font-size: 1.3em;
      "
    >
      <div
        class="adjustDie"
        data-dice="d4"
        data-adjust="qa"
        data-type="qa"
        style="justify-self: right; cursor: pointer"
      >
        <i
          class="color-purple fa-solid fa-rotate-left"
          data-adjust="reset"
          data-type="qa"
          title="{{localize " TA.Chat.ClickToReset"}}"
        ></i>
      </div>

      <div style="justify-self: left">
        <i
          id="lockOutcome"
          class="fa-solid fa-lock color-red"
          style="cursor: pointer"
          title="{{localize " TA.Chat.Lock"}}"
        ></i>
      </div>
    </div>

    <div
      style="
        justify-self: right;
        align-self: end;
        font-size: 14pt;
        padding: 0 10px 6px 0;
      "
    >
      <img
        class="icon"
        src="systems/triangleagency/assets/icons/qa.png"
        style="
          height: 18px;
          margin-top: -3px;
          margin-left: auto;
          margin-right: auto;
        "
        title="{{localize " TA.Chat.ClickToReset"}}"
      />
      <span style="display: inline-block; margin-left: 2px"> {{qa.remaining}} / {{qa.max}} </span>
    </div>
  </div>
  {{/unless}}

  {{#if primary.result.message}}
  <div style="margin-top: 5px"><span>{{{primary.result.message}}} {{{abilityMessage}}}</span></div>
  {{/if}}

  <div
    class="center"
    style="
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 0 5px;
      justify-items: center;
      border-top: 1px solid grey;
      margin-top: 6px;
      padding-top: 6px;
      font-size: 14pt;
    "
  >
    <div
      style="
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0 3px;
        align-items: center;
      "
    >
      <img
        class="icon"
        src="systems/triangleagency/assets/icons/burnout.svg"
        style="width: 14px; justify-self: right; margin-top: -5px"
        title="{{localize "TA.burnout"}}"
      />
      <div style="justify-self: left">{{burnout}}</div>
    </div>

    <div
      style="
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0 3px;
        align-items: center;
      "
    >
      <img
        class="icon"
        src="systems/triangleagency/assets/icons/chaos.svg"
        style="width: 16px; justify-self: right; margin-top: -2.5px"
        title="{{localize "TA.chaos"}}"
      />
      <div style="justify-self: left">{{effective.chaos}}</div>
    </div>

    <div
      style="
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0 2px;
        align-items: center;
      "
    >
      <img
        class="icon"
        src="systems/triangleagency/assets/icons/d4-success.png"
        style="width: 17px; justify-self: right; margin-top: -3px"
        title="{{localize "TA.successes"}}"
      />
      <div style="justify-self: left">{{effective.success}}</div>
    </div>
  </div>
</div>